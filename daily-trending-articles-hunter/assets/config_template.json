{
  "data_sources": {
    "we_mp_rss": {
      "enabled": true,
      "api_url": "http://localhost:3000/api",
      "mp_names": ["AI混子-俊"]
    },
    "hackernews": {
      "enabled": true,
      "api_url": "https://hacker-news.firebaseio.com/v0",
      "top_stories_limit": 30
    },
    "devto": {
      "enabled": true,
      "api_url": "https://dev.to/api",
      "top_articles_limit": 20
    },
    "juejin": {
      "enabled": true,
      "api_url": "https://api.juejin.cn",
      "category": "backend",
      "top_articles_limit": 20
    }
  },
  "keywords": {
    "AI工具": [
      "Claude",
      "Gemini",
      "Trae",
      "ChatGPT",
      "AI写作",
      "AI编程",
      "Copilot",
      "Cursor",
      "MCP",
      "Skill"
    ],
    "网页开发": [
      "Vercel",
      "部署",
      "前端",
      "React",
      "Next.js",
      "Node.js",
      "CSS",
      "HTML",
      "JavaScript",
      "TypeScript",
      "Docker"
    ],
    "内容创作": [
      "公众号",
      "爆文",
      "写作",
      "SEO",
      "内容营销",
      "标题优化",
      "流量"
    ]
  },
  "trending": {
    "min_score": 50,
    "time_decay_hours": 72,
    "platform_weights": {
      "公众号": 1.2,
      "HackerNews": 1.0,
      "dev.to": 0.9,
      "掘金": 1.1
    }
  },
  "feishu": {
    "app_id": "${FEISHU_APP_ID}",
    "app_secret": "${FEISHU_APP_SECRET}",
    "bitable_app_token": "${FEISHU_BITABLE_APP_TOKEN}",
    "table_id": "${FEISHU_TABLE_ID}"
  },
  "schedule": {
    "enabled": true,
    "cron_expression": "0 9 * * *",
    "timezone": "Asia/Shanghai"
  }
}
